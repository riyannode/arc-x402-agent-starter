# ── Required ──

# Reown (WalletConnect) project ID — get one free at https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# ── Arc Network ──

# Arc Testnet RPC URL (optional, defaults to dRPC endpoint)
# NEXT_PUBLIC_ARC_RPC_URL=https://rpc.drpc.testnet.arc.network

# ── x402 Receiver (where x402 payments go) ──

# The EOA address that receives x402 EIP-3009 payments.
# Production: set to your Circle Gateway or settlement wallet.
# X402_RECEIVER_ADDRESS=0x...

# Alternative pay-to address for x402 flows (used by server-side middleware)
# X402_PAY_TO=0x...

# ── x402 Per-Route Amount Overrides (atomic USDC, 6 decimals) ──

# 1 atomic unit = 0.000001 USDC
# X402_DEMO_AMOUNT_ATOMIC=1
# X402_PROTECTED_RESOURCE_AMOUNT_ATOMIC=1
# X402_REGISTER_GATE_AMOUNT_ATOMIC=1
# X402_CREATE_JOB_GATE_AMOUNT_ATOMIC=1
# X402_PREMIUM_PROOF_AMOUNT_ATOMIC=1

# ── Contract Addresses (for real mode) ──

# Set to enable real on-chain operations instead of demo/simulated mode.
# NEXT_PUBLIC_CONTRACT_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
# NEXT_PUBLIC_CONTRACT_AGENTIC_COMMERCE=0x0747EEf0706327138c69792bF28Cd525089e4583
# NEXT_PUBLIC_ARC_CHAIN_ID=5042002
